#!/usr/bin/env bash
# Write or escalate snooze state for eval-guide update checks.
# Usage: eval-guide-update-snooze <version>
set -euo pipefail

STATE_DIR="$HOME/.eval-guide"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
VERSION="${1:-unknown}"

mkdir -p "$STATE_DIR"

# Escalate snooze level if same version was snoozed before
PREV_LEVEL=0
if [[ -f "$SNOOZE_FILE" ]]; then
  PREV_VERSION="$(grep "^version:" "$SNOOZE_FILE" 2>/dev/null | sed 's/^[^:]*:[[:space:]]*//' | tr -d '[:space:]')" || true
  PREV_LEVEL="$(grep "^level:" "$SNOOZE_FILE" 2>/dev/null | sed 's/^[^:]*:[[:space:]]*//' | tr -d '[:space:]')" || true
  if [[ "$PREV_VERSION" != "$VERSION" ]]; then
    PREV_LEVEL=0  # New version — reset snooze level
  fi
fi

NEW_LEVEL=$(( ${PREV_LEVEL:-0} + 1 ))

cat > "$SNOOZE_FILE" <<EOF
version: $VERSION
level: $NEW_LEVEL
epoch: $(date +%s)
EOF

case "$NEW_LEVEL" in
  1) echo "Snoozed for 24 hours." ;;
  2) echo "Snoozed for 48 hours." ;;
  *) echo "Snoozed for 7 days." ;;
esac
